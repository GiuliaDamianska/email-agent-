# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth2 — create credentials at https://console.cloud.google.com
# App type: Desktop app. Enable Gmail API. Add http://localhost as redirect URI.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost

# Run `node auth.js` to get this, then paste it here
GMAIL_REFRESH_TOKEN=
